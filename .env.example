DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/saleshub
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# RS256 public key (PEM) used to verify JWTs minted by the auth service
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_AUDIENCE=

DEBUG=false
